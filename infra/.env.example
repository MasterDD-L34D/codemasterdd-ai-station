# CodeMasterDD AI Station — infra stack env template
# Copy to .env and fill with real values. .env is gitignored.

# =====================================================
# Langfuse web
# =====================================================
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET=changeme-generate-with-openssl-rand-base64-32
SALT=changeme-generate-with-openssl-rand-base64-32

# Admin user auto-creato al primo avvio
LANGFUSE_ADMIN_EMAIL=admin@codemasterdd.local
LANGFUSE_ADMIN_PASSWORD=changeme-min-8-chars

# API keys Langfuse: auto-seedate via LANGFUSE_INIT_PROJECT_*_KEY al primo up
# I default `pk-lf-codemasterdd-local` + `sk-lf-codemasterdd-local-change-me`
# funzionano out-of-box per sovereign single-user. Cambiare se deploy multi-user.
LANGFUSE_INIT_PUBLIC_KEY=pk-lf-codemasterdd-local
LANGFUSE_INIT_SECRET_KEY=sk-lf-codemasterdd-local-change-me
# Le variabili LANGFUSE_PUBLIC_KEY + LANGFUSE_SECRET_KEY usate dal LiteLLM
# callback sono settate automaticamente da docker-compose via expansion delle
# INIT_* sopra. Non serve ridefinirle qui.

# =====================================================
# Postgres (shared LiteLLM + Langfuse)
# Se modifichi queste dopo primo `docker compose up`, devi:
#   docker compose down -v    # cancella volume postgres (ATTENZIONE: perdi dati)
#   docker compose up -d      # re-inizializza con nuove password
# =====================================================
POSTGRES_ROOT_PASSWORD=postgres-local-change-me
LITELLM_DB_PASSWORD=litellm-local-change-me
LANGFUSE_DB_PASSWORD=langfuse-local-change-me

# =====================================================
# LiteLLM Proxy master key (admin UI + virtual key management)
# Cambiare assolutamente se esposto oltre localhost!
# =====================================================
LITELLM_MASTER_KEY=sk-local-masterkey-change-me

# =====================================================
# Provider API keys (tier 3-4)
# Metodo raccomandato: carica da ~/.config/api-keys/keys.env
# (storage centralizzato ACL-hardened, policy CodeMasterDD)
#
# Linux/Mac/WSL/Git Bash:
#   set -a; source ~/.config/api-keys/keys.env; set +a
#   docker compose up -d
#
# Windows PowerShell:
#   Get-Content ~/.config/api-keys/keys.env | ForEach-Object {
#     if ($_ -match '^([A-Z_]+)=(.+)$') {
#       [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process')
#     }
#   }
#   docker compose up -d
#
# Oppure (sconsigliato: keys nel .env del repo, anche se gitignored):
# GROQ_API_KEY=gsk_...
# CEREBRAS_API_KEY=csk_...
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...
# =====================================================
