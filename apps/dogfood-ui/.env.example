# apps/dogfood-ui/.env.example
# Copia in .env e popola con valori reali. Mai committare .env.
# FLASK_SECRET e' required: l'app fa fail-fast in mancanza (commit fix PR #96).
# Genera FLASK_SECRET con: python -c "import secrets; print(secrets.token_hex(32))"

# === Required ===
FLASK_SECRET=changeme-replace-with-python-secrets-token_hex

# === Optional -- dashboard config ===
PORT=8080
FLASK_DEBUG=

# === Optional -- integrations (default localhost se unset) ===
LITELLM_ENDPOINT=http://localhost:4000
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
DAFNE_HOST=http://localhost:5000
